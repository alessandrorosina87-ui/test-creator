rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permetti a tutti di leggere e scrivere il contatore per i codici progressivi
    match /verifiche/_contatore {
      allow read, write: if true;
    }
    
    // Verifiche collection
    // - Create: authenticated user must set user_id to their own uid
    // - Read/Update/Delete: only owner can access, or if user_id is missing (legacy) allow first access/claim
    match /verifiche/{docId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read: if request.auth != null && (!("user_id" in resource.data) || resource.data.user_id == request.auth.uid);
      allow update: if request.auth != null && (
        (!("user_id" in resource.data) && request.resource.data.user_id == request.auth.uid) || 
        resource.data.user_id == request.auth.uid
      );
      allow delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
  }
}
